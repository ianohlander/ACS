{
  "document": "ux-skinning-inventory",
  "version": 1,
  "purpose": "Track all live application UX elements and skinning connection points across Edit Mode and Play Mode.",
  "sources": [
    "apps/web/editor.html",
    "apps/web/index.html",
    "apps/web/styles.css",
    "apps/web/src/editor.ts",
    "apps/web/src/index.ts"
  ],
  "principles": [
    "Editor behavior must stay separate from editor presentation.",
    "Runtime rules must stay separate from gameplay presentation.",
    "Skins should target semantic UI surfaces, not business logic.",
    "Future milestones that add or change UI must update this inventory."
  ],
  "sharedPrimitives": {
    "tokens": [
      "--bg",
      "--panel",
      "--border",
      "--text",
      "--muted",
      "--accent"
    ],
    "classes": [
      "shell",
      "editor-shell",
      "topbar",
      "eyebrow",
      "layout",
      "editor-layout",
      "editor-layout-organized",
      "panel",
      "playfield-card",
      "button-row",
      "action-button",
      "save-status",
      "stack-field",
      "definition-grid",
      "validation-list",
      "event-log",
      "subhead",
      "section-kicker",
      "section-note"
    ]
  },
  "editModeAreas": [
    "Adventure Setup",
    "World Atlas",
    "Map Workspace",
    "Libraries",
    "Logic And Quests",
    "Test And Publish",
    "Validation"
  ],
  "playModeAreas": [
    "Runtime Top Bar",
    "Playfield",
    "Runtime Sidebar"
