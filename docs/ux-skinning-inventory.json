      "release and export action row",
      "release preview cards",
      "rename and reskin card",
      "diagnostics and scenario cards",
      "validation panel"
    ],
    "runtime": [
      "topbar mode controls",
      "play canvas",
      "dialogue overlay",
      "objective panel",
      "session source panel",
      "save/load/reset controls",
      "state summary panel",
      "event log panel"
    ]
  },
  "dynamicElements": {
    "editor": [
      "select options for content records",
      "map grid buttons and overlays",
      "pixel editor cells",
      "validation and diagnostics list items",
      "release and handoff summary list items",
      "condition and action builder rows",
      "rename preview rows"
    ],
    "runtime": [
      "event log rows",
      "dialogue visibility state",
      "runtime status values"
