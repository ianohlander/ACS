  },
  "connectionPoints": {
    "markupFiles": [
      "apps/web/editor.html",
      "apps/web/index.html"
    ],
    "styleFile": "apps/web/styles.css",
    "uiWiringFiles": [
      "apps/web/src/editor.ts",
      "apps/web/src/index.ts"
    ],
    "semanticClassesToPreserve": [
      "panel",
      "action-button",
      "stack-field",
      "definition-grid",
      "editor-section-card",
      "editor-nav",
      "editor-grid",
      "editor-cell",
      "validation-list",
      "reskin-card",
      "diagnostic-card",
      "dialogue",
      "playfield-card"
    ]
  },
  "futureSkeletonRequirements": [
    "Expand CSS custom properties into semantic theme tokens.",
    "Introduce reusable semantic UI primitive components for panels, buttons, fields, lists, chips, and overlays.",
    "Create explicit screen-level skin slots for editor and runtime shells.",
    "Add icon, border, background, divider, and illustration attachment points.",
    "Keep presenter adapters separate from editor-core and runtime-core logic.",
    "Update this inventory on every milestone that changes visible UI."
  ]
