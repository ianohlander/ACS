{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@acs/domain": ["packages/domain/src/index.ts"],
      "@acs/content-schema": ["packages/content-schema/src/index.ts"],
      "@acs/runtime-core": ["packages/runtime-core/src/index.ts"],
      "@acs/runtime-2d": ["packages/runtime-2d/src/index.ts"],
      "@acs/persistence": ["packages/persistence/src/index.ts"],
      "@acs/editor-core": ["packages/editor-core/src/index.ts"],
      "@acs/project-api": ["packages/project-api/src/index.ts"],
      "@acs/validation": ["packages/validation/src/index.ts"]
    }
  }
}
