{
  "name": "acs",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "node ./node_modules/typescript/lib/tsc.js -b",
    "typecheck": "node ./node_modules/typescript/lib/tsc.js -b --pretty",
    "test:unit": "node ./tools/run-unit-tests.mjs",
    "test:coverage": "node ./tools/run-unit-tests.mjs --coverage",
    "test:ui": "powershell -ExecutionPolicy Bypass -File ./tools/editor-ui-smoke.ps1",
    "test": "npm run test:unit && npm run test:ui && npm run playtest:smoke",
    "quality:complexity": "node ./tools/complexity-check.mjs",
    "quality": "npm run quality:complexity && npm run typecheck",
    "serve:web": "node ./apps/web/server.mjs",
    "serve:api": "node ./apps/api/dist/index.js",
    "clean": "git clean -xfd -e .git",
    "playtest:smoke": "npm run build && node ./tools/playtest-smoke.mjs"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
