{
  "name": "acs",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "node ./node_modules/typescript/lib/tsc.js -b",
    "typecheck": "node ./node_modules/typescript/lib/tsc.js -b --pretty",
    "quality:complexity": "node ./tools/complexity-check.mjs",
    "quality": "npm run quality:complexity && npm run typecheck",
    "serve:web": "node ./apps/web/server.mjs",
    "serve:api": "node ./apps/api/dist/index.js",
    "clean": "git clean -xfd -e .git"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
