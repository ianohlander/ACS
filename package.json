{
  "name": "acs",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty",
    "serve:web": "node ./apps/web/server.mjs",
    "serve:api": "node ./apps/api/dist/index.js",
    "clean": "git clean -xfd -e .git"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
